          <item>
           <widget class="QLineEdit" name="lineEdit_account">
            <property name="styleSheet">
             <string notr="true">/* 设置LineEdit样式 - 添加边框和背景色 */
QLineEdit {
    border: 1px solid #CCCCCC;      /* 浅灰色边框 */
    border-radius: 4px;             /* 圆角边框 */
    padding: 5px 10px;              /* 内边距 */
    font-size: 16px;                /* 字体大小 */
    background-color: #FFFFFF;      /* 白色背景 */
    color: #333333;                 /* 深灰色字体 */
    font-family: &quot;黑体&quot;, &quot;SimHei&quot;;  /* 黑体字体 */
    selection-background-color: #1E90FF;  /* 选中文本背景色 */
}

/* LineEdit获取焦点时的样式 */
QLineEdit:focus {
    border: 1px solid #1E90FF;      /* 蓝色边框 */
    outline: none;                  /* 取消默认焦点轮廓 */
}

/* LineEdit提示词样式 */
QLineEdit::placeholder {
    color: #999999;                 /* 浅灰色提示词 */
    font-size: 13px;                /* 提示词字体大小 */
    font-style: italic;             /* 斜体 */
}</string>
            </property>
           </widget>
