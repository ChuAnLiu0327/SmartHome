       <item>
        <widget class="QPushButton" name="pushButton_login">
         <property name="styleSheet">
          <string notr="true">/* 设置按钮样式 */
QPushButton {
    /* 边框设置 */
    border: 2px solid #2E8B57;           /* 海绿色边框 */
    border-radius: 8px;                  /* 圆角边框 */
    
    /* 背景渐变 - 从上到下的渐变 */
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #20B2AA, stop:1 #3CB371);
    
    /* 字体设置 */
    color: white;                        /* 白色字体 */
    font-size: 14px;                     /* 字体大小 */
    font-family: &quot;黑体&quot;, &quot;SimHei&quot;;        /* 黑体字体 */
    font-weight: bold;                   /* 字体加粗 */
    
    /* 内边距 */
    padding: 8px 16px;                   /* 上下8px，左右16px */
    
    /* 文本对齐 */
    text-align: center;
   
}

/* 鼠标悬停时的按钮样式 */
QPushButton:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #40E0D0, stop:1 #66CDAA);
    border: 2px solid #228B22;           /* 悬停时边框变深 */
    color: white;
}

/* 按钮按下时的样式 */
QPushButton:pressed {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #008B8B, stop:1 #2E8B57);
    border: 2px solid #006400;           /* 按下时边框更深 */
    padding: 9px 16px 7px 16px;          /* 模拟按下效果 */
}

/* 按钮焦点状态（键盘导航） */
QPushButton:focus {
    outline: none;                      /* 取消默认焦点轮廓 */
    border: 2px solid #1E90FF;          /* 焦点时蓝色边框 */
}</string>
