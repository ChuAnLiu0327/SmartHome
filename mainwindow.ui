           <item>
            <widget class="QWidget" name="widget_3" native="true">
             <layout class="QVBoxLayout" name="verticalLayout_2">
              <item>
               <widget class="QPushButton" name="uploadConfigBtn">
                <property name="styleSheet">
                 <string notr="true">/* 基础样式 */
QPushButton#uploadConfigBtn {
    /* 背景色：匹配图中的蓝紫色 */
    background-color: #4E5AF1;
    /* 文字颜色：白色 */
    color: white;
    /* 去掉默认边框 */
    border: none;
    /* 圆角大小：8px 匹配视觉效果 */
    border-radius: 8px;
    /* 内边距：上下10px，左右16px，左侧额外留出图标位置 */
    padding: 10px 16px;
    padding-left: 32px;
    /* 字体样式 */
    font-family: &quot;Microsoft YaHei&quot;, Arial, sans-serif;
    font-size: 18px;
    /* 图标位置：左侧10px居中（如果你用背景图做图标） */
    background-repeat: no-repeat;
    background-position: left 10px center;
}

/* 鼠标悬浮状态 */
QPushButton#uploadConfigBtn:hover {
    background-color: #434EDC;
}

/* 鼠标按下状态 */
QPushButton#uploadConfigBtn:pressed {
    background-color: #3A44C8;
}

/* 禁用状态 */
QPushButton#uploadConfigBtn:disabled {
    background-color: #B4B8F5;
    color: #E0E0E0;
}</string>
                </property>
                <property name="text">
                 <string>上传配置文件</string>
                </property>
                <property name="icon">
                 <iconset resource="icons/upload.qrc">
                  <normaloff>:/new/prefix1/upload.png</normaloff>:/new/prefix1/upload.png</iconset>
