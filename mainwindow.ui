          <layout class="QHBoxLayout" name="horizontalLayout">
           <item>
            <widget class="QLineEdit" name="lineEdit_send_message">
             <property name="styleSheet">
              <string notr="true">/* QTextEdit 基础样式 */
QLineEdit {
    /* 背景色：浅灰色，柔和不刺眼 */
    background-color: #f8f9fa;
    /* 边框：浅灰色，圆角8px（可调整） */
    border: 1px solid #dee2e6;
    border-radius: 8px;
    /* 内边距：避免文字贴边框，上下左右各10px */
    padding: 10px;
    /* 文字样式：默认字体，14px大小，深灰色文字 */
    font-family: &quot;Microsoft YaHei&quot;, Arial, sans-serif;
    font-size: 20px;
    /* 禁用默认的焦点虚线框 */
    outline: none;
}

/* 鼠标悬浮状态 */
QLineEdit:hover {
    border-color: #adb5bd;
    background-color: #f1f3f5;
}

/* 获得焦点状态（激活） */
QLineEdit:focus {
    border-color: #4dabf7;
    /* 轻微外发光效果，增强焦点提示 */
}

/* 选中文本的背景色 */
QLineEdit::selection {
    background-color: #4dabf7;
    color: white;
}

/* 禁用状态 */
QLineEdit:disabled {
    background-color: #e9ecef;
    color: #adb5bd;
    border-color: #e9ecef;
}

/* ---------- 配套滚动条美化 ---------- */
/* 滚动条整体 */
QLineEdit QScrollBar:vertical {
    width: 8px;
    background-color: transparent;
    margin: 0px;
}

/* 滚动条滑块 */
QLineEdit QScrollBar::handle:vertical {
    background-color: #ced4da;
    border-radius: 4px;
    min-height: 20px;
}

/* 滑块悬浮 */
QLineEdit QScrollBar::handle:vertical:hover {
    background-color: #adb5bd;
}

/* 滚动条上下箭头（隐藏） */
QLineEdit QScrollBar::sub-line:vertical,
QLineEdit QScrollBar::add-line:vertical {
    height: 0px;
}

/* 水平滚动条（按需启用） */
QLineEdit QScrollBar:horizontal {
    height: 8px;
    background-color: transparent;
    margin: 0px;
}

QLineEdit QScrollBar::handle:horizontal {
    background-color: #ced4da;
    border-radius: 4px;
    min-width: 20px;
}

QLineEdit QScrollBar::handle:horizontal:hover {
    background-color: #adb5bd;
}

QLineEdit QScrollBar::sub-line:horizontal,
QLineEdit QScrollBar::add-line:horizontal {
    width: 0px;
}</string>
             </property>
            </widget>
           </item>
           <item>
            <widget class="QPushButton" name="pushButton_ai_send">
             <property name="styleSheet">
              <string notr="true">/* 发送按钮基础样式 */
QPushButton { /* 使用ID选择器，避免影响其他按钮 */
    /* 背景颜色（示例中的蓝色，可根据需要调整） */
    background-color: #2196F3; /* Material Design 标准蓝色 */
    /* 文字样式 */
    color: white; /* 白色文字 */
    font-size: 20px; /* 字体大小 */
    font-weight: 500; /* 字体粗细（可选，增强层次感） */
    /* 边框与圆角 */
    border: none; /* 无边框 */
    border-radius: 6px; /* 圆角（示例中的圆角约6px） */
    /* 内边距（按钮内容与边框的间距，避免拥挤） */
    padding: 10px 20px; /* 上下10px，左右20px */
    /* 图标设置 */
    icon-size: 16px; /* 图标大小（与文字匹配） */
    /* 最小宽高（确保按钮不会太小） */
    min-width: 120px; /* 最小宽度 */
    min-height: 36px; /* 最小高度 */
}

/*  hover 效果（鼠标悬停时） */
QPushButton:hover {
    background-color: #1976D2; /* 更深的蓝色（增强交互反馈） */
}

/*  pressed 效果（鼠标按下时） */
QPushButton:pressed {
    background-color: #1565C0; /* 更暗的蓝色（模拟按压感） */
}</string>
             </property>
             <property name="text">
              <string>发送</string>
             </property>
             <property name="icon">
              <iconset resource="icons/send.qrc">
               <normaloff>:/new/prefix1/send_baise.png</normaloff>:/new/prefix1/send_baise.png</iconset>
             </property>
             <property name="iconSize">
              <size>
               <width>32</width>
               <height>32</height>
              </size>
             </property>
            </widget>
           </item>
          </layout>
         </widget>
        </item>
       </layout>
      </widget>
