                  <string>发送</string>
                 </property>
                 <property name="icon">
                  <iconset resource="icons/send.qrc">
                   <normaloff>:/new/prefix1/send_baise.png</normaloff>:/new/prefix1/send_baise.png</iconset>
                 </property>
                 <property name="iconSize">
                  <size>
                   <width>32</width>
                   <height>32</height>
                  </size>
                 </property>
                </widget>
