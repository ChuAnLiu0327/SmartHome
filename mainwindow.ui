        <iconset resource="icons/video.qrc">
         <normaloff>:/new/prefix1/video.png</normaloff>:/new/prefix1/video.png</iconset>
       </attribute>
       <attribute name="title">
        <string>视频通话</string>
       </attribute>
      </widget>
     </widget>
    </item>
